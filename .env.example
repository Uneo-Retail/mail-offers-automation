# ─────────────────────────────────────────────────────────────
# Microsoft Graph (boîte Outlook M365, auth daemon client_credentials)
# ─────────────────────────────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=matthieu@uneo-retail.com

# ─────────────────────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MODEL_CLASSIFY=claude-haiku-4-5-20251001
MODEL_EXTRACT=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────
# Notion (API version gérant les data sources)
# ─────────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_VERSION=2025-09-03
NOTION_DS_OFFRES=29b545f7-7d1b-80db-87c4-000b800d1928
NOTION_DS_MAGASINS=29a545f7-7d1b-8198-8c48-000b58d15f80
NOTION_DS_EMPLACEMENTS=29a545f7-7d1b-8126-a235-000b671734c4
NOTION_DS_BROKERS=29a545f7-7d1b-8042-a782-000b9e431263
NOTION_DS_CONTACTS=29a545f7-7d1b-80ba-b5bc-000bb889c53a
NOTION_DS_VILLES=29a545f7-7d1b-80d2-a35c-000ba4ede17a

# ─────────────────────────────────────────────────────────────
# Azure Blob Storage (fichiers : PDF, plans, photos)
# ─────────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=offres-uneo
# Durée de vie des URLs SAS générées (en jours). Container privé + SAS = défaut recommandé (données de baux).
AZURE_SAS_TTL_DAYS=3650

# ─────────────────────────────────────────────────────────────
# Supabase (état : deltaLink, mails traités, logs)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────
# Divers
# ─────────────────────────────────────────────────────────────
# Secret partagé pour protéger le cron (Vercel envoie Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
# 1 offre par lot (défaut) | local = 1 offre par local
OFFER_GRANULARITY=lot
# Nombre max de mails traités par exécution de cron (filet de sécurité). Défaut 40.
MAX_BATCH=40
# Traiter volontairement l'historique au 1er run (true). Par défaut absent → amorçage sans traitement.
FORCE_BACKFILL=
# Garde-fou « plaquette dense » (multi-centres type Terranae) : au-delà, on signale au lieu d'extraire en masse.
DENSE_BROCHURE_MAX_CENTERS=5
DENSE_BROCHURE_MAX_PAGES=30
