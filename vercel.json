{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'no build step - serverless functions only'",
  "outputDirectory": ".",
  "functions": {
    "api/poll.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/**"
    },
    "api/process.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/**"
    }
  }
}
